# Copy to config/local.env (gitignored) and fill in your values.
# Used by shell scripts and as a reference for extension/server setup.

SERVER_IP=YOUR_SERVER_IP
SSH_KEY=$HOME/.ssh/id_ed25519_do

# Must match server/.env and extension/relay-core.local.js
SECRET_KEY=change-me-same-as-server-env

# Optional — also set in server/.env on the droplet
PARTICIPANT_UID=YOUR_STUDENT_ID
PARTICIPANT_EMAIL=you@student.kuleuven.be
