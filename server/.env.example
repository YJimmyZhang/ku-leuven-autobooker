# Required — must match extension/relay-core.local.js
SECRET_KEY=replace-with-a-long-random-string

# Public hostname for HTTPS (Caddy gets a free Let's Encrypt cert for it).
# Create a free one at https://www.duckdns.org and point it at the droplet IP.
# Example: DOMAIN=yourname.duckdns.org
DOMAIN=yourname.duckdns.org

# Your KU student details (defaults until changed in /admin runtime config)
PARTICIPANT_UID=YOUR_STUDENT_ID
PARTICIPANT_EMAIL=you@student.kuleuven.be

# Booking schedule (TZ=Europe/Brussels on the server)
BOOKING_ENABLED=true
BOOKING_PERIOD_START=2026-06-01
BOOKING_PERIOD_END=2026-07-15

# Set BOOKING_ENABLED=false after exam period to keep server up without booking.
